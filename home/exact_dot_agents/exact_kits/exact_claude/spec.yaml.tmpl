schemaVersion: "1"
kind: mixin
name: local-claude-code
displayName: Local Claude Code

commands:
  startup:
    - command:
        - sh
        - -c
        - |
          set -eu

          settings=/home/agent/.claude/settings.json
          mkdir -p /home/agent/.claude
          [ -f "$settings" ] || printf '{}' > "$settings"

          local_settings=$(printf '%s' '{{ include "dot_config/claude/private_settings.json" | b64enc }}' \
            | base64 -d)
          jq --argjson local_settings "$local_settings" '. * $local_settings' "$settings" \
            > "${settings}.tmp"

          mv -- "${settings}.tmp" "$settings"
