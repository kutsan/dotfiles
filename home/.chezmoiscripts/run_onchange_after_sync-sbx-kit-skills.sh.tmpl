#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

# .agents tree hash: {{ output "sh" "-c" (printf "cd %q && find exact_dot_agents -type f -exec cat {} +" .chezmoi.sourceDir) | sha256sum }}

{{ template "logger.sh" . }}

mirror_dir_contents() {
	local -r src=$1 dest=$2

	find "${dest}" -mindepth 1 -delete
	cp -RL -- "${src}/." "${dest}/"
}

main() {
	local -r source_dir="${HOME}/.agents/skills"
	local -r kits_dir="${HOME}/.agents/kits"

	if [[ ! -d "${source_dir}" ]]; then
		log.warn "Skills source ${source_dir} not found; skipping."
		return 0
	fi

	local kit_skills

	log.info "Syncing agent skills into \`${kits_dir#"${HOME}/"}\`..."

	while IFS= read -r -d '' kit_skills; do
		mirror_dir_contents "${source_dir}" "${kit_skills}"
	done < <(find "${kits_dir}" -type d -name skills -print0)

	log.success "Kit skills synced."
}

main "$@"
