#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

{{ $fileHashes := "" -}}
{{- range (glob (joinPath .chezmoi.sourceDir "exact_dot_agents" "**")) -}}
{{-   if not (stat .).isDir -}}
{{-     $fileHashes = printf "%s\n%s:%s" $fileHashes . (include . | sha256sum) -}}
{{-   end -}}
{{- end -}}
# sync hash: {{ $fileHashes | sha256sum }}

{{ template "logger.sh" . }}

mirror_dir_contents() {
	local -r src=$1 dest=$2

	if [[ ! -d "${src}" ]]; then
		log.error "Source directory missing: ${src}"
		return 1
	fi

	mkdir -p -- "${dest}"
	find "${dest}" -mindepth 1 -delete
	cp -RL -- "${src}/." "${dest}/"
}

main() {
	log.info "Syncing shared config into agent kits..."

	mirror_dir_contents \
		"${HOME}/.agents/skills" \
		"${HOME}/.config/sbx/kits/claude/files/home/.claude/skills"

	log.success "Kit config synced."
}

main "$@"
