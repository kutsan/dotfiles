#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

# sync hash: {{ output "sh" "-c" (printf "cd %q && find exact_dot_agents -type f -exec cat {} +" .chezmoi.sourceDir) | sha256sum }}

{{ template "logger.sh" . }}

mirror_dir_contents() {
	local -r src=$1 dest=$2

	find "${dest}" -mindepth 1 -delete
	cp -RL -- "${src}/." "${dest}/"
}

main() {
	log.info "Syncing shared config into agent kits..."

	mirror_dir_contents \
		"${HOME}/.agents/skills" \
		"${HOME}/.config/sbx/kits/claude/files/home/.claude/skills"

	log.success "Kit config synced."
}

main "$@"
