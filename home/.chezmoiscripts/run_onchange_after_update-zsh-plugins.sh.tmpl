#!/usr/bin/env bash

# plugins-lock.csv hash: {{ include "dot_config/exact_zsh/plugins-lock.csv" | sha256sum }}

set -o errexit -o nounset -o pipefail
IFS=$'\n\t'

{{ template "logger.sh" . }}

main() {
	log.info "Updating Zsh plugins..."

	# Run interactive zsh to load zinit.
	zsh -ic 'zinit update --all --no-pager'

	log.success "Zsh plugins updated."
}

main "$@"
