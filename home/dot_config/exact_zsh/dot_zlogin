# Cache directory should be created manually since zsh doesn't create
# XDG Base Directory paths automatically.
typeset -g zsh_cache_dir="$XDG_CACHE_HOME/zsh"

if (! [[ -d "$zsh_cache_dir" ]]) {
	command mkdir -p "$zsh_cache_dir"
}

# Asynchronously zcompile .zcompdump file.
{
	local zcompdump_path="$zsh_cache_dir/zcompdump"

	if ([[ -s "$zcompdump_path" && (! -s "${zcompdump_path}.zwc" || "$zcompdump_path" -nt "${zcompdump_path}.zwc") ]]) {
		zcompile "$zcompdump_path"
	}
} &!

unset zsh_cache_dir
